# Multica connected-agent runtime — environment.
# Copy to .env and fill in, then: docker compose up -d --build
# Never commit a filled-in copy — only this .example belongs in git.

# ── Multica (required for daemon mode; omit MULTICA_TOKEN for an interactive shell)
# Personal access token (mul_... or mcn_...). Generate at https://multica.ai/settings/tokens
MULTICA_TOKEN=mul_xxxxxxxxxxxxxxxxxxxxxxxx
# Workspace to claim tasks from (optional; can also pass --workspace-id at runtime)
MULTICA_WORKSPACE_ID=
# Display name for this runtime. Also the default stable daemon id.
MULTICA_AGENT_RUNTIME_NAME=multica-agent-runtime
# Stable daemon id so reruns reuse the same runtime instead of registering a new
# one. Defaults to MULTICA_AGENT_RUNTIME_NAME if unset.
# MULTICA_DAEMON_ID=multica-agent-runtime
# Optional overrides (defaults shown)
# MULTICA_SERVER_URL=https://api.multica.ai
# MULTICA_APP_URL=https://multica.ai

# ── GitHub (so the daemon + agents can clone/push private repos and open/merge PRs)
# Classic PAT scopes: `repo` (+ `workflow` if agents edit .github/workflows). Or a
# fine-grained PAT with Contents RW, Pull requests RW, Metadata R (+ Workflows RW,
# Checks R as needed). Used for git HTTPS auth and exported as GH_TOKEN for gh.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional one-time bootstrap, run before the daemon starts.
# Provision a project toolchain or register MCP servers without rebuilding the
# image. Examples:
#   SETUP_CMD=mise install
#   SETUP_CMD=add-mcp https://example.com/mcp --name foo -a claude-code -a codex -g -y
# SETUP_CMD=

# ── OpenCode DeepSeek provider (optional; configured in opencode.json, key read here)
# API key from https://platform.deepseek.com/ — read by opencode via {env:DEEPSEEK_API_KEY}.
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# Make the opencode runtime use DeepSeek (multica's MULTICA_<PROVIDER>_MODEL override).
# MULTICA_OPENCODE_MODEL=deepseek/deepseek-chat
