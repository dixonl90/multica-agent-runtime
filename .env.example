# Dev image (agent-runtime/Dockerfile) environment.
# Copy to agent-runtime/.env and fill in, then run one of:
#   docker run --rm --env-file agent-runtime/.env ... florence-dev        # quick test
#   docker run --rm -v "$(pwd)/agent-runtime/.env:/app/.env" ... florence-dev   # entrypoint sources /app/.env
# Never commit a filled-in copy — only this .example belongs in git.

# ── Multica (required for daemon mode; omit MULTICA_TOKEN for an interactive shell)
# Personal access token (mul_... or mcn_...). Generate at https://multica.ai/settings/tokens
MULTICA_TOKEN=mul_xxxxxxxxxxxxxxxxxxxxxxxx
# Workspace to claim tasks from
MULTICA_WORKSPACE_ID=5d59ac4d-9609-4d84-940a-b7f1a9e1c3a9
# Stable daemon id so reruns reuse the same runtime instead of registering a new one.
# Defaults to MULTICA_AGENT_RUNTIME_NAME ("florence-dev") if unset.
MULTICA_DAEMON_ID=florence-dev
# Optional overrides (defaults shown)
# MULTICA_SERVER_URL=https://api.multica.ai
# MULTICA_APP_URL=https://multica.ai
# MULTICA_AGENT_RUNTIME_NAME=florence-dev

# ── GitHub (clone/push private repo + agents opening/merging PRs)
# Fine-grained PAT scoped to dixonl90/go-with-the-flo with repository permissions:
#   Contents: Read and write        (clone, fetch, push)
#   Pull requests: Read and write   (open, update, merge PRs)
#   Metadata: Read                  (mandatory, auto-selected)
#   Workflows: Read and write       (only if agents edit .github/workflows/*)
#   Checks / Commit statuses: Read  (only if gating merges on green CI)
# Classic PAT equivalent: scopes `repo` (+ `workflow` if editing workflow files).
# Used for git HTTPS auth and exported as GH_TOKEN for the gh CLI.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Stitch MCP (optional; registered at runtime so the key stays out of the image)
STITCH_API_KEY=AQ.xxxxxxxxxxxxxxxxxxxxxxxx

# ── DeepSeek (optional; the DeepSeek provider is baked into opencode's config)
# API key from https://platform.deepseek.com/ — read by opencode via {env:DEEPSEEK_API_KEY}.
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# Make the opencode runtime use DeepSeek (multica's MULTICA_<PROVIDER>_MODEL override).
# MULTICA_OPENCODE_MODEL=deepseek/deepseek-chat

# ── Supabase (optional; only if the app needs cloud sync during dev)
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=
