# Multica connected-agent runtime — environment.
# Copy to .env and fill in, then: docker compose up -d --build
# Never commit a filled-in copy — only this .example belongs in git.

# ── Multica (required for daemon mode; omit MULTICA_TOKEN for an interactive shell)
# Personal access token (mul_... or mcn_...). Generate at https://multica.ai/settings/tokens
MULTICA_TOKEN=mul_xxxxxxxxxxxxxxxxxxxxxxxx
# Workspace to claim tasks from (optional; can also pass --workspace-id at runtime)
MULTICA_WORKSPACE_ID=
# Display name for this runtime. Also the default stable daemon id.
MULTICA_AGENT_RUNTIME_NAME=multica-agent-runtime
# Stable daemon id so reruns reuse the same runtime instead of registering a new
# one. Defaults to MULTICA_AGENT_RUNTIME_NAME if unset.
# MULTICA_DAEMON_ID=multica-agent-runtime
# Optional overrides (defaults shown)
# MULTICA_SERVER_URL=https://api.multica.ai
# MULTICA_APP_URL=https://multica.ai

# ── GitHub (so the daemon + agents can clone/push private repos and open/merge PRs)
# Classic PAT scopes: `repo` (+ `workflow` if agents edit .github/workflows). Or a
# fine-grained PAT with Contents RW, Pull requests RW, Metadata R (+ Workflows RW,
# Checks R as needed). Used for git HTTPS auth and exported as GH_TOKEN for gh.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxx

# ── GitLab (optional; for cloning/pushing GitLab repos and opening MRs via glab)
# Personal access token, scopes: `api` + `write_repository` (`read_repository` if
# agents only need read). Used for git HTTPS auth and read by glab directly.
# GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
# Host WITHOUT scheme. Omit for gitlab.com; set for self-managed, e.g. gitlab.example.com
# GITLAB_HOST=gitlab.com

# ── Gitea / Forgejo (optional; clone/push + open PRs via the `tea` CLI)
# Access token from <instance>/user/settings/applications with repo + PR scopes.
# GITEA_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Instance host WITHOUT scheme, required for Gitea/Forgejo (self-hosted, no default).
# GITEA_HOST=gitea.example.com
# Optional: git HTTPS username (the token is the password; default oauth2 works on Gitea).
# GITEA_USER=oauth2
# Optional: name for the tea login profile (default: gitea).
# GITEA_LOGIN_NAME=gitea

# ── AI agent auth (optional). The daemon may supply model credentials itself; set
# these only to give an agent CLI your own key/subscription. All are read from the
# environment headlessly, with no interactive login needed (and none would persist
# anyway, since the agent config dirs are not mounted as volumes).
#
# Claude Code: API billing, or a subscription token from `claude setup-token`
# (run that on a machine with a browser, then paste the token here). Set one.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# CLAUDE_CODE_OAUTH_TOKEN=
#
# OpenAI Codex: API billing. Do NOT also run `codex login`; the env key silently
# overrides the OAuth token, which causes surprise billing / 401s.
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
#
# OpenCode: uses per-provider keys (see opencode.json); the DeepSeek example is below.
#
# Antigravity (agy): GEMINI_API_KEY is IGNORED; use these. TOKEN is for CI/headless.
# ANTIGRAVITY_API_KEY=
# ANTIGRAVITY_TOKEN=

# ── Optional one-time bootstrap, run before the daemon starts.
# Provision a project toolchain or register MCP servers without rebuilding the
# image. Examples:
#   SETUP_CMD=mise install
#   SETUP_CMD=add-mcp https://example.com/mcp --name foo -a claude-code -a codex -g -y
# SETUP_CMD=

# ── OpenCode DeepSeek provider (optional; configured in opencode.json, key read here)
# API key from https://platform.deepseek.com/ — read by opencode via {env:DEEPSEEK_API_KEY}.
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# Make the opencode runtime use DeepSeek (multica's MULTICA_<PROVIDER>_MODEL override).
# MULTICA_OPENCODE_MODEL=deepseek/deepseek-chat

# ── Hermes Agent: API key for the hermes CLI
# HERMES_API_KEY=
#
# ── Pi Coding Agent: API key for the pi CLI
# PI_API_KEY=
#
# ── OpenClaw: API key for the openclaw CLI
# OPENCLAW_API_KEY=
